# Google OAuth2 — create credentials at https://console.cloud.google.com/apis/credentials
# App type: Web application
# Authorized redirect URI: http://localhost:8080/auth/callback  (or your deployed URL)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Random secret strings for cookie signing/encryption (run: openssl rand -hex 32)
SECRET_KEY=change-me-to-32-plus-random-chars
SECRET_BLOCK_KEY=change-me-to-another-32-plus-random-chars

# Optional
PORT=8080
DATA_DIR=.   # where cache.db is stored
